@startuml
participant ":FitLogger" as FL
participant ":Storage" as ST
participant ":Scanner" as SC
participant ":WorkoutList" as WL

FL -> ST : loadData(profile)
ST -> ST : check file exists
alt file does not exist
    ST --> FL : empty list
else file exists
    ST -> SC : new Scanner(file)
    loop for each line
        SC --> ST : line
        alt line is profile (line 1)
            ST -> ST : parseProfile(line, profile)
        else line starts with R
            ST -> ST : parseRunWorkout(fields)
            ST --> WL : RunWorkout
        else line starts with L
            ST -> ST : parseStrengthWorkout(fields)
            ST --> WL : StrengthWorkout
        else corrupted line
            ST -> ST : print warning, skip
        end
    end
    ST --> FL : List<Workout>
end
FL -> WL : addWorkout(each)
@enduml