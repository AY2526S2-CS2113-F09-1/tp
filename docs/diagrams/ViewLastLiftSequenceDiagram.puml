@startuml
actor User
participant ":FitLogger" as FL
participant ":Parser" as P
participant ":ViewLastLiftCommand" as CMD
participant ":WorkoutList" as WL
participant ":Ui" as UI

User -> FL : lastlift Bench Press
FL -> P : parse(...)
P --> FL : ViewLastLiftCommand("Bench Press")
FL -> CMD : execute(storage, workouts, ui, profile)
CMD -> WL : getSize()
loop i from last to 0
    CMD -> WL : getWorkoutAtIndex(i)
    WL --> CMD : workout
    alt workout is StrengthWorkout and name matches
        CMD -> UI : showLastLift(lift)
        UI --> User : displays stats
        CMD --> FL : return
    end
end
alt no match found
    CMD -> UI : showMessage("No record found...")
end
@enduml
